# RSS Feed Configuration
# ======================
# 読み込むOPMLファイル名 (デフォルト: default_rss.opml)
OPML_FILE=default_rss.opml

# Gmail Configuration
# ==================
# 送信元のGmailアドレス
GMAIL_ADDRESS=your.email@gmail.com

# Gmailアプリパスワード（通常のパスワードではありません）
# 取得方法:
#   1. Googleアカウントで2段階認証を有効化
#   2. https://myaccount.google.com/apppasswords にアクセス
#   3. 生成された16文字のパスワードをここに貼り付け
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email Recipients
# ================
# 個人のメールアドレス（送信先）
PERSONAL_EMAIL=your.email@gmail.com
# 会社のメールアドレス（送信先）
COMPANY_EMAIL=your.email@company.com

# Ollama Configuration
# ===============================
# デフォルト: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
