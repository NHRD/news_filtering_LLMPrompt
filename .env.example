# Gmail Configuration
# ==================
# 送信元のGmailアドレス
GMAIL_ADDRESS=your.email@gmail.com

# Gmailアプリパスワード（通常のパスワードではありません）
# 取得方法:
#   1. Googleアカウントで2段階認証を有効化
#   2. https://myaccount.google.com/apppasswords にアクセス
#   3. 「アプリを選択」→「その他」→ 任意の名前（例: "RSS News Filter"）
#   4. 生成された16文字のパスワードをここに貼り付け
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email Recipients
# ================
# 個人のメールアドレス（送信先）
PERSONAL_EMAIL=your.email@gmail.com
# 会社のメールアドレス（送信先）
COMPANY_EMAIL=your.email@company.com

# Ollama Configuration (Optional)
# ===============================
# デフォルト: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
